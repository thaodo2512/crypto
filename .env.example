# Crypto Signal Bot — Environment Variables
# Copy this file to .env — NEVER commit .env to git
#
# Required variables are marked [REQUIRED], optional are [OPTIONAL]

# ─── Telegram Bot ────────────────────────────────────────
# [REQUIRED] Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# [REQUIRED] Your Telegram chat ID for receiving alerts
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Anthropic API (Claude AI Analysis) ─────────────────
# [OPTIONAL] AI analysis layer is optional — system works without it
ANTHROPIC_API_KEY=sk-ant-your_api_key_here

# ─── Exchange API Keys ──────────────────────────────────
# [OPTIONAL] Only needed if using authenticated endpoints
# Public data endpoints (used by this bot) don't require API keys
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# ─── FRED API (Macro Economic Data) ─────────────────────
# [REQUIRED] Free API key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ─── Finnhub API (Economic Calendar) ─────────────────────
# [OPTIONAL] Finnhub economic calendar uses free endpoint (no key required)
FINNHUB_API_KEY=

# ─── Coinglass ──────────────────────────────────────────
# [OPTIONAL] Free tier API key from https://www.coinglass.com/
COINGLASS_API_KEY=

# ─── Database ───────────────────────────────────────────
# [OPTIONAL] Override default SQLite path (default: data/signals.db)
DATABASE_PATH=data/signals.db

# ─── Deployment ─────────────────────────────────────────
# [OPTIONAL] Set to "production" on VPS
ENVIRONMENT=development
